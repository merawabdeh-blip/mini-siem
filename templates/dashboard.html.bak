<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mini SIEM Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #0f172a;
            color: white;
        }

        .header {
            padding: 24px;
            text-align: center;
            border-bottom: 1px solid #334155;
            background: #111827;
        }

        .header h1 {
            margin: 0;
            font-size: 32px;
        }

        .header p {
            margin-top: 10px;
            color: #cbd5e1;
        }

        .token-bar, .filter-bar, .action-bar {
            display: flex;
            gap: 10px;
            padding: 16px 24px;
            background: #1e293b;
            border-bottom: 1px solid #334155;
            flex-wrap: wrap;
        }

        .token-bar input,
        .filter-bar input,
        .filter-bar select {
            flex: 1;
            min-width: 180px;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #475569;
            background: #0f172a;
            color: white;
        }

        .token-bar button,
        .action-bar button {
            padding: 10px 16px;
            border: none;
            border-radius: 8px;
            background: #2563eb;
            color: white;
            cursor: pointer;
            font-weight: bold;
        }

        .token-bar button:hover,
        .action-bar button:hover {
            background: #1d4ed8;
        }

        .main { padding: 20px; }

        .stats, .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 16px;
            margin-bottom: 20px;
        }

        .card {
            background: #1e293b;
            border-radius: 14px;
            padding: 18px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

        .card h3 {
            margin: 0 0 8px 0;
            font-size: 16px;
            color: #cbd5e1;
        }

        .card .value {
            font-size: 28px;
            font-weight: bold;
        }

        .grid {
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 20px;
        }

        .panel {
            background: #1e293b;
            border-radius: 14px;
            padding: 18px;
            min-height: 300px;
        }

        .panel h2 {
            margin-top: 0;
            margin-bottom: 16px;
            border-bottom: 1px solid #334155;
            padding-bottom: 10px;
        }

        .entry {
            background: #0f172a;
            border: 1px solid #334155;
            padding: 12px;
            border-radius: 10px;
            margin-bottom: 12px;
        }

        .entry strong {
            display: block;
            margin-bottom: 6px;
        }

        .meta {
            color: #cbd5e1;
            font-size: 14px;
            line-height: 1.5;
        }

        .tag {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: bold;
            margin-right: 6px;
        }

        .high { background: #7f1d1d; color: #fecaca; }
        .medium { background: #78350f; color: #fde68a; }
        .low { background: #064e3b; color: #bbf7d0; }
        .critical { background: #450a0a; color: #fca5a5; }
        .unknown { background: #334155; color: #e2e8f0; }

        .type-list div,
        .ip-list div {
            margin-bottom: 10px;
            padding: 10px;
            background: #0f172a;
            border-radius: 10px;
            border: 1px solid #334155;
        }

        .chart-wrap {
            height: 320px;
            position: relative;
        }

        .muted {
            color: #94a3b8;
        }

        .footer-note {
            margin-top: 20px;
            color: #94a3b8;
            font-size: 14px;
            text-align: center;
        }

        @media (max-width: 900px) {
            .grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>AI-Enhanced Mini SIEM Dashboard</h1>
        <p>Real-time security monitoring, alert visualization, AI-assisted detection, filtering, and reporting</p>
    </div>

    <div class="token-bar">
        <input type="text" id="tokenInput" placeholder="Paste Bearer token here" />
        <button onclick="saveToken()">Save Token</button>
        <button onclick="clearToken()">Clear Token</button>
        <button onclick="fetchDashboardData()">Refresh</button>
    </div>

    <div class="filter-bar">
        <input type="text" id="searchInput" placeholder="Search logs (message, source, event type, IP)..." />
        <input type="text" id="sourceInput" placeholder="Filter by source (e.g. wazuh, test)" />
        <input type="text" id="eventTypeInput" placeholder="Filter by event type" />
        <select id="severitySelect">
            <option value="">All severities</option>
            <option value="low">low</option>
            <option value="medium">medium</option>
            <option value="high">high</option>
            <option value="critical">critical</option>
            <option value="3">3</option>
            <option value="7">7</option>
        </select>
    </div>

    <div class="action-bar">
        <button onclick="fetchDashboardData()">Apply Filters</button>
        <button onclick="exportLogsCSV()">Export Logs CSV</button>
        <button onclick="exportAlertsCSV()">Export Alerts CSV</button>
    </div>

    <div class="main">
        <div class="stats">
            <div class="card">
                <h3>Total Logs</h3>
                <div class="value" id="totalLogs">-</div>
            </div>
            <div class="card">
                <h3>Total Alerts</h3>
                <div class="value" id="totalAlerts">-</div>
            </div>
            <div class="card">
                <h3>Most Frequent Alert</h3>
                <div class="value" id="topAlertType">-</div>
            </div>
            <div class="card">
                <h3>Top Source IP</h3>
                <div class="value" id="topIP">-</div>
            </div>
            <div class="card">
                <h3>AI Status</h3>
                <div class="value" id="aiStatus">Active</div>
            </div>
            <div class="card">
                <h3>Last Refresh</h3>
                <div class="value" id="lastRefresh">-</div>
            </div>
        </div>

        <div class="panel" style="margin-bottom:20px;">
            <h2>Model Metrics</h2>
            <div class="metrics-grid">
                <div class="card">
                    <h3>Model</h3>
                    <div class="value" id="modelName">-</div>
                </div>
                <div class="card">
                    <h3>Accuracy</h3>
                    <div class="value" id="modelAccuracy">-</div>
                </div>
                <div class="card">
                    <h3>Precision</h3>
                    <div class="value" id="modelPrecision">-</div>
                </div>
                <div class="card">
                    <h3>Recall</h3>
                    <div class="value" id="modelRecall">-</div>
                </div>
                <div class="card">
                    <h3>F1 Score</h3>
                    <div class="value" id="modelF1">-</div>
                </div>
                <div class="card">
                    <h3>Training Dataset</h3>
                    <div class="value" id="trainingDataset">-</div>
                </div>
            </div>
        </div>

        <div class="grid">
            <div class="panel">
                <h2>Recent Alerts</h2>
                <div id="alertsBox"><span class="muted">Loading alerts...</span></div>
            </div>

            <div class="panel">
                <h2>Recent Logs</h2>
                <div id="logsBox"><span class="muted">Loading logs...</span></div>
            </div>
        </div>

        <div class="grid" style="margin-top: 20px;">
            <div class="panel">
                <h2>Attack Types Summary</h2>
                <div id="typeSummary" class="type-list"><span class="muted">Loading summary...</span></div>
            </div>

            <div class="panel">
                <h2>Top Source IPs</h2>
                <div id="ipSummary" class="ip-list"><span class="muted">Loading IP summary...</span></div>
            </div>
        </div>

        <div class="grid" style="margin-top: 20px;">
            <div class="panel">
                <h2>Alert Types Chart</h2>
                <div class="chart-wrap">
                    <canvas id="alertTypesChart"></canvas>
                </div>
            </div>

            <div class="panel">
                <h2>Severity Distribution</h2>
                <div class="chart-wrap">
                    <canvas id="severityChart"></canvas>
                </div>
            </div>
        </div>

        <div class="footer-note">
            Dashboard auto-refreshes every 5 seconds.
        </div>
    </div>

    <script>
        let alertTypesChart = null;
        let severityChart = null;

        function saveToken() {
            const token = document.getElementById("tokenInput").value.trim();
            localStorage.setItem("siem_token", token);
            alert("Token saved successfully.");
            fetchDashboardData();
        }

        function clearToken() {
            localStorage.removeItem("siem_token");
            document.getElementById("tokenInput").value = "";
            alert("Token cleared.");
        }

        function getToken() {
            return localStorage.getItem("siem_token") || "";
        }

        function getHeaders() {
            return {
                "Authorization": "Bearer " + getToken()
            };
        }

        function severityTag(severity) {
            const sev = String(severity || "unknown").toLowerCase();
            const cls = ["high", "medium", "low", "critical"].includes(sev) ? sev : "unknown";
            return `<span class="tag ${cls}">${sev.toUpperCase()}</span>`;
        }

        function countByKey(items, key) {
            const counts = {};
            for (const item of items) {
                const value = item[key] || "UNKNOWN";
                counts[value] = (counts[value] || 0) + 1;
            }
            return counts;
        }

        function getTopEntry(countsObj) {
            const entries = Object.entries(countsObj);
            if (!entries.length) return ["-", 0];
            entries.sort((a, b) => b[1] - a[1]);
            return entries[0];
        }

        function renderSummary(containerId, countsObj, labelName) {
            const box = document.getElementById(containerId);
            const entries = Object.entries(countsObj).sort((a, b) => b[1] - a[1]).slice(0, 8);

            if (!entries.length) {
                box.innerHTML = `<span class="muted">No ${labelName} available</span>`;
                return;
            }

            box.innerHTML = entries.map(([name, count]) => `
                <div>
                    <strong>${name}</strong>
                    <div class="meta">Count: ${count}</div>
                </div>
            `).join("");
        }

        function destroyCharts() {
            if (alertTypesChart) {
                alertTypesChart.destroy();
                alertTypesChart = null;
            }
            if (severityChart) {
                severityChart.destroy();
                severityChart = null;
            }
        }

        function renderCharts(alertTypeCounts, severityCounts) {
            destroyCharts();

            const alertCtx = document.getElementById("alertTypesChart").getContext("2d");
            const severityCtx = document.getElementById("severityChart").getContext("2d");

            alertTypesChart = new Chart(alertCtx, {
                type: "bar",
                data: {
                    labels: Object.keys(alertTypeCounts),
                    datasets: [{
                        label: "Alert Count",
                        data: Object.values(alertTypeCounts)
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { labels: { color: "white" } }
                    },
                    scales: {
                        x: {
                            ticks: { color: "white" },
                            grid: { color: "#334155" }
                        },
                        y: {
                            beginAtZero: true,
                            ticks: { color: "white" },
                            grid: { color: "#334155" }
                        }
                    }
                }
            });

            severityChart = new Chart(severityCtx, {
                type: "doughnut",
                data: {
                    labels: Object.keys(severityCounts),
                    datasets: [{
                        data: Object.values(severityCounts)
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { labels: { color: "white" } }
                    }
                }
            });
        }

        function getFilters() {
            const q = document.getElementById("searchInput").value.trim();
            const source = document.getElementById("sourceInput").value.trim();
            const eventType = document.getElementById("eventTypeInput").value.trim();
            const severity = document.getElementById("severitySelect").value.trim();

            const params = new URLSearchParams();
            if (q) params.append("q", q);
            if (source) params.append("source", source);
            if (eventType) params.append("event_type", eventType);
            if (severity) params.append("severity", severity);

            return params.toString();
        }

        async function fetchModelMetrics() {
            try {
                const res = await fetch("/logs/model-metrics", { headers: getHeaders() });
                if (!res.ok) throw new Error("Could not load model metrics");

                const metrics = await res.json();

                document.getElementById("modelName").innerText = metrics.model_name || "-";
                document.getElementById("modelAccuracy").innerText = metrics.accuracy ?? "-";
                document.getElementById("modelPrecision").innerText = metrics.precision ?? "-";
                document.getElementById("modelRecall").innerText = metrics.recall ?? "-";
                document.getElementById("modelF1").innerText = metrics.f1_score ?? "-";
                document.getElementById("trainingDataset").innerText = metrics.training_dataset || "-";
            } catch {
                document.getElementById("modelName").innerText = "Error";
                document.getElementById("modelAccuracy").innerText = "-";
                document.getElementById("modelPrecision").innerText = "-";
                document.getElementById("modelRecall").innerText = "-";
                document.getElementById("modelF1").innerText = "-";
                document.getElementById("trainingDataset").innerText = "-";
            }
        }

        async function fetchDashboardData() {
            const logsBox = document.getElementById("logsBox");
            const alertsBox = document.getElementById("alertsBox");
            const filters = getFilters();

            try {
                const logsUrl = filters ? `/logs/?${filters}` : "/logs/";
                const alertsUrl = "/logs/alerts";

                const [logsRes, alertsRes] = await Promise.all([
                    fetch(logsUrl, { headers: getHeaders() }),
                    fetch(alertsUrl, { headers: getHeaders() })
                ]);

                if (!logsRes.ok || !alertsRes.ok) {
                    throw new Error("Unauthorized or failed to fetch data. Make sure the token is valid.");
                }

                const logs = await logsRes.json();
                const alerts = await alertsRes.json();

                document.getElementById("totalLogs").innerText = logs.length;
                document.getElementById("totalAlerts").innerText = alerts.length;

                const alertTypeCounts = countByKey(alerts, "type");
                const ipCounts = countByKey(alerts, "source_ip");
                const severityCounts = countByKey(alerts, "severity");

                const [topAlertType] = getTopEntry(alertTypeCounts);
                const [topIP] = getTopEntry(ipCounts);

                document.getElementById("topAlertType").innerText = topAlertType;
                document.getElementById("topIP").innerText = topIP;
                document.getElementById("lastRefresh").innerText = new Date().toLocaleTimeString();

                renderSummary("typeSummary", alertTypeCounts, "types");
                renderSummary("ipSummary", ipCounts, "IPs");
                renderCharts(alertTypeCounts, severityCounts);

                if (!alerts.length) {
                    alertsBox.innerHTML = `<span class="muted">No alerts yet</span>`;
                } else {
                    alertsBox.innerHTML = alerts.slice(0, 12).map(alert => `
                        <div class="entry">
                            <strong>${alert.type || "UNKNOWN"} - ${alert.source_ip || "-"}</strong>
                            <div class="meta">${severityTag(alert.severity)} ${alert.timestamp || ""}</div>
                            <div class="meta">${alert.description || "No description"}</div>
                        </div>
                    `).join("");
                }

                if (!logs.length) {
                    logsBox.innerHTML = `<span class="muted">No logs found for current filters</span>`;
                } else {
                    logsBox.innerHTML = logs.slice(0, 12).map(log => `
                        <div class="entry">
                            <strong>${log.event_type || "UNKNOWN"} - ${log.source || "-"}</strong>
                            <div class="meta">${severityTag(log.severity)} ${log.timestamp || ""}</div>
                            <div class="meta">IP: ${log.source_ip || "-"}</div>
                            <div class="meta">Risk Score: ${log.risk_score ?? "-"}</div>
                            <div class="meta">${log.message || ""}</div>
                        </div>
                    `).join("");
                }

                await fetchModelMetrics();

            } catch (error) {
                destroyCharts();
                logsBox.innerHTML = `<span class="muted">Could not load logs</span>`;
                alertsBox.innerHTML = `<span class="muted">Could not load alerts</span>`;
                document.getElementById("totalLogs").innerText = "Error";
                document.getElementById("totalAlerts").innerText = "Error";
                document.getElementById("topAlertType").innerText = "-";
                document.getElementById("topIP").innerText = "-";
                document.getElementById("typeSummary").innerHTML = `<span class="muted">${error.message}</span>`;
                document.getElementById("ipSummary").innerHTML = `<span class="muted">${error.message}</span>`;
            }
        }

        function exportLogsCSV() {
            const filters = getFilters();
            const url = filters ? `/logs/export/csv?${filters}` : "/logs/export/csv";

            fetch(url, { headers: getHeaders() })
                .then(response => {
                    if (!response.ok) throw new Error("Could not export logs");
                    return response.blob();
                })
                .then(blob => {
                    const link = document.createElement("a");
                    link.href = URL.createObjectURL(blob);
                    link.download = "logs_export.csv";
                    link.click();
                })
                .catch(error => alert(error.message));
        }

        function exportAlertsCSV() {
            fetch("/logs/alerts/export/csv", { headers: getHeaders() })
                .then(response => {
                    if (!response.ok) throw new Error("Could not export alerts");
                    return response.blob();
                })
                .then(blob => {
                    const link = document.createElement("a");
                    link.href = URL.createObjectURL(blob);
                    link.download = "alerts_export.csv";
                    link.click();
                })
                .catch(error => alert(error.message));
        }

        window.onload = () => {
            const savedToken = getToken();
            if (savedToken) {
                document.getElementById("tokenInput").value = savedToken;
            }
            fetchDashboardData();
            setInterval(fetchDashboardData, 5000);
        };
    </script>
</body>
</html>
